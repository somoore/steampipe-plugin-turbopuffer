#!/usr/bin/env bash
# Pre-commit hook: enforce Steampipe standards before a commit lands.
# Runs `make test` (gofmt check + vet + standards/unit tests).
# Install with: make hooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: running make test ..."
if ! make test; then
  echo
  echo "pre-commit: standards checks failed — commit aborted."
  echo "Fix the issues above (or run 'gofmt -w .'), then commit again."
  exit 1
fi
